{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "📡 Monitor Serial (115200)",
            "type": "shell",
            "command": "pio",
            "args": ["device", "monitor", "-b", "115200"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "🔨 Build + Upload + Monitor",
