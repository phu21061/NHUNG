            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "🔋 Debug Monitor — INA226 & Energy",
            "type": "shell",
            "command": "pio",
            "args": [
                "device", "monitor",
                "-b", "115200"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
