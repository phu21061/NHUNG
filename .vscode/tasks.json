        {
            "label": "🏗️ Build Only",
            "type": "shell",
            "command": "pio",
            "args": ["run"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
