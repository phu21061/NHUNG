            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": []
        },
        {
            "label": "_pio_upload",
            "type": "shell",
            "command": "pio",
            "args": ["run", "--target", "upload"],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "🐛 Debug Monitor — Radar & AI",
            "type": "shell",
            "command": "pio",
            "args": [
                "device", "monitor",
                "-b", "115200",
